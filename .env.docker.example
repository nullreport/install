# NullReport docker-compose environment.
# Copy to .env and fill in the REQUIRED values. Anything left blank uses the
# default shown in docker-compose.prod.yml.
#
# The one-line installer generates this file for you with strong random
# secrets. Use this template only if you set things up by hand.

# ----- REQUIRED ------------------------------------------------------------

# Random 32+ char string. Signs the session JWT cookie.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Random 64-char hex (32 bytes). Encrypts API keys at rest in the DB.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ----- OPTIONAL — defaults are fine for most installs -----------------------

# Postgres credentials (only matters if you expose port 5432; internal network
# uses these too).
POSTGRES_USER=nullreport
POSTGRES_PASSWORD=nullreport
POSTGRES_DB=nullreport

# Port the frontend (and your browser) connects to. Defaults to 3000.
FRONTEND_PORT=3000

# Used by the backend's CORS allowlist. Set this if you put a custom domain
# in front of the frontend container.
FRONTEND_URL=http://localhost:3000

# ----- TIER & LICENSING — set if you bought a Pro or Team license ---------

# free | pro | team. Must MATCH (or be lower than) your LICENSE_KEY's tier.
# Selects which prebuilt image is pulled — paid feature code is physically
# absent from lower tiers. Change this and re-run the installer (or
# `docker compose pull && docker compose up -d`) whenever you upgrade.
TIER=free

# Without LICENSE_KEY the app runs in free tier. Your purchase emails you a
# key like NR-PRO-... or NR-TEAM-...
LICENSE_KEY=

# Where the backend talks to for license activation. Defaults to the
# production NullReport license server; only change for a self-hosted license
# server or local development.
LICENSE_SERVER_URL=https://license.nullreport.app
